# MongoDB connection settings
MONGO_URI=mongodb://localhost:27017
MONGO_DB=my_database

# Optional: MongoDB authentication (leave blank if not required)
MONGO_USER=
MONGO_PASSWORD=

# Directory where backups will be stored (default: ./backups)
BACKUP_DIR=./backups

# Number of backups to keep (default: 3)
BACKUP_RETENTION=3

# Cron schedule for daily backup (default: 2:00 AM every day)
# Format: second minute hour day month weekday
BACKUP_CRON=0 0 2 * * *
